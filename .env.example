# ---------------------------------------------------------------------------
# milvus_station environment template (SPEC-INFRA-001).
#
# Copy to .env and adjust for your host:   cp .env.example .env
# The real .env is git-ignored (N1) - never commit credentials.
# Values below are SAFE LOCAL DEFAULTS suitable for a dev bring-up.
# ---------------------------------------------------------------------------

# --- MariaDB -----------------------------------------------------------------
# Root password is only used inside the container network (no host port).
MARIADB_ROOT_PASSWORD=change-me-root
# Application database created + seeded on first boot.
MARIADB_DATABASE=milvus_station
# Application user. SPEC-INFRA-001 mandates the milvus/milvus credentials,
# which are also the phpMyAdmin login used in the hello-world milestone.
MARIADB_USER=milvus
MARIADB_PASSWORD=milvus

# --- MinIO (Milvus object storage) -------------------------------------------
# Consumed by both the minio service and the milvus standalone container.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Ingress (nginx) ---------------------------------------------------------
# The ONLY port published to the host. Everything else is internal-only.
INGRESS_PORT=38005
# Must match the public URL + /mysql/ subpath so phpMyAdmin emits correct links.
PMA_ABSOLUTE_URI=http://localhost:38005/mysql/

# --- Ollama (embedding runtime) ----------------------------------------------
# Model to pull into the ollama volume. Actual pull + embedding/search wiring
# is DEFERRED to SPEC-SEARCH-002; documented here for forward compatibility.
OLLAMA_MODEL=nomic-embed-text
